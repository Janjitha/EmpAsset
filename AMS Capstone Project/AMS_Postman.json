            "http://localhost:8080"
          ],
          "path": [
            "api",
            "auth",
            "profile"
          ]
        },
        "description": "Returns the logged-in employee's profile details extracted from the JWT token.\n\nExpected Response:\n{\n  \"id\": 1,\n  \"username\": \"john.doe\",\n  \"role\": \"EMPLOYEE\",\n  \"createdAt\": \"2024-01-15T10:00:00Z\"\n}"
      }
    },
